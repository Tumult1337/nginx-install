user                 www-data;
worker_processes     auto;
worker_cpu_affinity  auto;
worker_rlimit_nofile 1048576;
pid                  /run/nginx.pid;
error_log            /var/log/nginx/error.log warn;
include              /etc/nginx/modules-enabled/*.conf;

events {
    worker_connections 65536;
    multi_accept       on;
    use                epoll;
    accept_mutex       off;
}

http {
    # MIME and charset
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;
    charset       utf-8;

    # Core / I/O
    server_tokens              off;
    sendfile                   on;
    sendfile_max_chunk         2m;
    tcp_nopush                 on;
    tcp_nodelay                on;
    types_hash_max_size        4096;
    server_names_hash_bucket_size 128;
    variables_hash_max_size    2048;
    map_hash_bucket_size       128;

    # Header / body buffers
    client_header_buffer_size   4k;
    large_client_header_buffers 4 16k;
    client_body_buffer_size     128k;
    client_max_body_size        64m;

    # Internal memory pools
    connection_pool_size 512;
    request_pool_size    4k;

    # Timeouts
    keepalive_timeout         65s;
    keepalive_requests        10000;
    send_timeout              10s;
    client_header_timeout     10s;
    client_body_timeout       10s;
    reset_timedout_connection on;
    lingering_close           on;
    lingering_time            30s;
    lingering_timeout         5s;

    # File descriptor cache
    open_file_cache          max=200000 inactive=60s;
    open_file_cache_valid    30s;
    open_file_cache_min_uses 2;
    open_file_cache_errors   on;

    # Compression
    gzip              on;
    gzip_vary         on;
    gzip_proxied      any;
    gzip_comp_level   5;
    gzip_min_length   1024;
    gzip_buffers      16 8k;
    gzip_http_version 1.1;
    gzip_types
        text/plain text/css text/xml text/javascript
        application/javascript application/json application/xml
        application/xml+rss application/atom+xml application/rss+xml
        application/wasm font/ttf font/otf image/svg+xml;
{{- if .Brotli}}

    # Brotli (dynamic module: libnginx-mod-http-brotli-{filter,static})
    brotli            on;
    brotli_comp_level 5;
    brotli_min_length 1024;
    brotli_static     on;
    brotli_types
        text/plain text/css text/xml text/javascript
        application/javascript application/json application/xml
        application/xml+rss application/atom+xml application/rss+xml
        application/wasm font/ttf font/otf image/svg+xml;
{{- end}}

    # TLS — modern only (1.2 + 1.3)
    ssl_protocols             TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers               'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_ecdh_curve            X25519:secp384r1;
    ssl_session_timeout       1d;
    ssl_session_cache         shared:SSL:50m;
    ssl_session_tickets       off;
    ssl_buffer_size           4k;
    ssl_stapling              on;
    ssl_stapling_verify       on;
    resolver                  1.1.1.1 9.9.9.9 valid=300s ipv6=on;
    resolver_timeout          5s;

    # HTTP/2
    http2_max_concurrent_streams 128;

    # Rate-limit / connection-limit zones (referenced by non-CF vhost configs).
    limit_conn_zone $binary_remote_addr zone=perip:32m;
    limit_req_zone  $binary_remote_addr zone=reqip:32m rate=50r/s;

    # Proxy defaults
    proxy_http_version     1.1;
    proxy_socket_keepalive on;
    proxy_set_header       Host              $host;
    proxy_set_header       X-Real-IP         $remote_addr;
    proxy_set_header       X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header       X-Forwarded-Proto $scheme;
    proxy_set_header       X-Forwarded-Host  $host;
    proxy_set_header       Connection        "";
    proxy_connect_timeout  5s;
    proxy_send_timeout     60s;
    proxy_read_timeout     60s;
    proxy_buffering        on;
    proxy_buffer_size      16k;
    proxy_buffers          32 16k;
    proxy_busy_buffers_size  64k;
    proxy_max_temp_file_size 0;
    proxy_request_buffering  on;

    # JSON access log — skip 2xx/3xx, buffer writes
    log_format json escape=json
        '{'
            '"ts":"$time_iso8601",'
            '"remote":"$remote_addr",'
            '"host":"$host",'
            '"method":"$request_method",'
            '"uri":"$request_uri",'
            '"status":$status,'
            '"bytes":$body_bytes_sent,'
            '"referer":"$http_referer",'
            '"ua":"$http_user_agent",'
            '"rt":$request_time,'
            '"upstream":"$upstream_addr",'
            '"upstream_status":"$upstream_status",'
            '"upstream_rt":"$upstream_response_time",'
            '"ssl_proto":"$ssl_protocol",'
            '"ssl_cipher":"$ssl_cipher"'
        '}';

    map $status $loggable {
        ~^[23] 0;
        default  1;
    }

    access_log /var/log/nginx/access.log json buffer=64k flush=5s if=$loggable;

    # Operator-managed http-scope snippets (maps, custom log formats, etc.).
    # nginx-gen never writes here — drop your own .conf files in conf.d/ and
    # they will survive --main re-renders.
    include /etc/nginx/conf.d/*.conf;

    # Vhosts (managed by `nginx-gen <host> <target>`).
    include /etc/nginx/sites-enabled/*.conf;
}
